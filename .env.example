# ============================================================================
# Django Core Settings
# ============================================================================

DJANGO_SETTINGS_MODULE=coriza.settings

# SECRET_KEY - مفتاح سري للتشفير والتوقيعات
# ⚠️ CRITICAL: يجب تغيير هذا المفتاح في الإنتاج!
# لتوليد مفتاح آمن، استخدم:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-random-50-character-string-in-production

# DEBUG - وضع التطوير
# ⚠️ SECURITY: يجب تعيينه إلى false في الإنتاج!
# القيمة الافتراضية الآن: false (آمن)
DEBUG=true

# ALLOWED_HOSTS - النطاقات المسموح بها
ALLOWED_HOSTS=localhost,127.0.0.1,[::1]

# CSRF_TRUSTED_ORIGINS - أصول CSRF الموثوقة
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# CORS_ALLOWED_ORIGINS - أصول CORS المسموح بها
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000

# ============================================================================
# Database Configuration
# ============================================================================

DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
# DB_USER=
# DB_PASSWORD=
# DB_HOST=
# DB_PORT=

# ============================================================================
# Redis & Celery (Background Tasks)
# ============================================================================

# ⚠️ NOTE: Celery is optional. If not installed, the app will work without background tasks.
# To install: pip install celery redis
REDIS_URL=redis://127.0.0.1:6379/1
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# ============================================================================
# Email Configuration
# ============================================================================

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@coriza.local
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=

# ============================================================================
# External API Keys (Optional)
# ============================================================================

# VirusTotal API Key (للحصول على نتائج حقيقية من VirusTotal)
# احصل على مفتاح مجاني من: https://www.virustotal.com/gui/join-us
# VIRUSTOTAL_API_KEY=

# AlienVault OTX API Key (لاستخبارات التهديدات)
# احصل على مفتاح مجاني من: https://otx.alienvault.com/
# OTX_API_KEY=

# ============================================================================
# Logging & Monitoring
# ============================================================================

DJANGO_LOG_LEVEL=INFO

# Sentry (اختياري - لتتبع الأخطاء في الإنتاج)
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.2
# SENTRY_SEND_DEFAULT_PII=false
# SENTRY_ENVIRONMENT=production

# ============================================================================
# Production Security Settings (uncomment for production)
# ============================================================================

# ⚠️ IMPORTANT: في الإنتاج، يجب تفعيل هذه الإعدادات:

# DEBUG=false
# SECRET_KEY=<generate-a-new-random-key>
# ALLOWED_HOSTS=coriza.cloud,www.coriza.cloud
# CSRF_TRUSTED_ORIGINS=https://coriza.cloud,https://www.coriza.cloud
# CORS_ALLOWED_ORIGINS=https://coriza.cloud

# SSL/HTTPS Settings (for production behind reverse proxy)
# SECURE_SSL_REDIRECT=true
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=true
# SECURE_HSTS_PRELOAD=true
# SESSION_COOKIE_SECURE=true
# CSRF_COOKIE_SECURE=true
