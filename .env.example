# Django settings
DJANGO_SETTINGS_MODULE=coriza.settings
SECRET_KEY=change-me
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,[::1]
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000

# Database
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
# DB_USER=
# DB_PASSWORD=
# DB_HOST=
# DB_PORT=

# Redis / Celery
REDIS_URL=redis://127.0.0.1:6379/1
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@coriza.local
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=

# Logging & Monitoring
DJANGO_LOG_LEVEL=INFO
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.2
# SENTRY_SEND_DEFAULT_PII=false
# SENTRY_ENVIRONMENT=production

# Optional production overrides (uncomment and set on server)
# DEBUG=false
# ALLOWED_HOSTS=coriza.cloud,127.0.0.1,localhost
# CSRF_TRUSTED_ORIGINS=https://coriza.cloud
# CORS_ALLOWED_ORIGINS=https://coriza.cloud
